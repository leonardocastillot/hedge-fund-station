{
  "appId": "com.hedgefund.station",
  "productName": "Hedge Fund Station",
  "copyright": "Copyright © 2026 Leonardo Castillo",
  "publish": [
    {
      "provider": "github",
      "owner": "leonardocastillot",
      "repo": "hedge-fund-station"
    }
  ],
  "directories": {
    "output": "release/${version}",
    "buildResources": "resources"
  },
  "files": [
    "dist",
    "dist-electron",
    "!src",
    "!electron",
    "!*.md",
    "!.env"
  ],
  "asarUnpack": [
    "node_modules/node-pty/**"
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64", "x64"]
      },
      {
        "target": "zip",
        "arch": ["arm64", "x64"]
      }
    ],
    "category": "public.app-category.finance",
    "icon": "resources/icon.icns",
    "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.inherit.plist",
    "extendInfo": {
      "NSMicrophoneUsageDescription": "Hedge Fund Station uses the microphone only when the operator starts voice transcription for local agent commands.",
      "NSCameraUsageDescription": "Hedge Fund Station does not use the camera by default. Embedded web content may request camera access if the operator opens a site that requires it.",
      "NSBluetoothAlwaysUsageDescription": "Hedge Fund Station does not use Bluetooth by default.",
      "NSBluetoothPeripheralUsageDescription": "Hedge Fund Station does not use Bluetooth by default."
    }
  },
  "dmg": {
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "resources/icon.ico",
    "artifactName": "${productName}-${version}-Setup.${ext}",
    "publisherName": "Leonardo Castillo"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "installerIcon": "resources/icon.ico",
    "uninstallerIcon": "resources/icon.ico",
    "installerHeaderIcon": "resources/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Hedge Fund Station",
    "deleteAppDataOnUninstall": false,
    "displayLanguageSelector": false
  },
  "portable": {
    "artifactName": "${productName}-${version}-Portable.${ext}"
  }
}
