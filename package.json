{
  "name": "hedge-fund-station",
  "version": "1.0.0",
  "description": "Native desktop app for hedge fund operations, trading, and workspace management with integrated terminals",
  "main": "dist-electron/main/index.js",
  "author": {
    "name": "Moon Dev",
    "email": "noreply@moondev.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/moondev/hedge-fund-station",
  "repository": {
    "type": "git",
    "url": "https://github.com/moondev/hedge-fund-station.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "mission:drill": "node scripts/mission-drill.mjs --workspace .",
    "hf:doctor": "powershell -ExecutionPolicy Bypass -File scripts/hf.ps1 doctor",
    "hf:strategy:new": "powershell -ExecutionPolicy Bypass -File scripts/hf.ps1 strategy new",
    "hf:backtest": "powershell -ExecutionPolicy Bypass -File scripts/hf.ps1 backtest",
    "hf:validate": "powershell -ExecutionPolicy Bypass -File scripts/hf.ps1 validate",
    "hf:paper": "powershell -ExecutionPolicy Bypass -File scripts/hf.ps1 paper",
    "hf:status": "powershell -ExecutionPolicy Bypass -File scripts/hf.ps1 status",
    "build:clean": "rm -rf dist dist-electron release && npm run build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:dir": "npm run build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.576.0",
    "node-pty": "^1.0.0",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^2.0.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^3.4.19",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
