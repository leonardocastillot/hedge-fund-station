{
  "name": "hedge-fund-station",
  "version": "1.0.0",
  "description": "Native desktop app for hedge fund operations, trading, and workspace management with integrated terminals",
  "main": "dist-electron/main/index.js",
  "author": {
    "name": "Leonardo Castillo",
    "email": "noreply@example.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/leonardocastillot/hedge-fund-station",
  "repository": {
    "type": "git",
    "url": "https://github.com/leonardocastillot/hedge-fund-station.git"
  },
  "scripts": {
    "dev": "electron-vite dev --watch",
    "dev:mac": "./open-hedge-fund-station-dev.command",
    "build": "electron-vite build",
    "terminal:doctor": "node scripts/fix-node-pty-permissions.mjs --smoke",
    "mission:drill": "node scripts/mission-drill.mjs --workspace .",
    "perf:budget": "node scripts/perf-budget.mjs",
    "graph:build": "uvx --python 3.11 --from graphifyy graphify update . --force",
    "graph:update": "uvx --python 3.11 --from graphifyy graphify update .",
    "graph:query": "sh -c 'uvx --python 3.11 --from graphifyy graphify query \"$*\" --graph graphify-out/graph.json' --",
    "graph:explain": "sh -c 'uvx --python 3.11 --from graphifyy graphify explain \"$*\" --graph graphify-out/graph.json' --",
    "graph:path": "sh -c 'uvx --python 3.11 --from graphifyy graphify path \"$@\" --graph graphify-out/graph.json' --",
    "graph:check": "node scripts/graphify-check.mjs",
    "agent:init": "python3 scripts/agent_harness.py init",
    "agent:status": "python3 scripts/agent_harness.py status",
    "agent:check": "python3 scripts/agent_harness.py check",
    "hf:doctor": "python3 scripts/hf.py doctor",
    "hf:strategy:new": "python3 scripts/hf.py strategy new",
    "hf:backtest": "python3 scripts/hf.py backtest",
    "hf:validate": "python3 scripts/hf.py validate",
    "hf:paper": "python3 scripts/hf.py paper",
    "hf:paper:tick": "python3 scripts/hf.py paper-runtime-tick",
    "hf:paper:loop": "python3 scripts/hf.py paper-runtime-loop",
    "hf:paper:supervisor": "bash scripts/btc-paper-runtime-loop.sh",
    "hf:doubling:stability": "python3 scripts/hf.py doubling-stability",
    "hf:btc:optimize": "python3 scripts/hf.py btc-optimize",
    "hf:agent:research": "python3 scripts/hf.py agent research",
    "hf:agent:audit": "python3 scripts/hf.py agent audit",
    "hf:agent:status": "python3 scripts/hf.py agent status",
    "hf:agent:runtime": "python3 scripts/hf.py agent runtime",
    "hf:status": "python3 scripts/hf.py status",
    "backend:tunnel": "scripts/backend-tunnel.sh run",
    "backend:tunnel:install": "scripts/backend-tunnel.sh install",
    "backend:tunnel:start": "scripts/backend-tunnel.sh start",
    "backend:tunnel:stop": "scripts/backend-tunnel.sh stop",
    "backend:tunnel:status": "scripts/backend-tunnel.sh status",
    "backend:health": "curl -fsS http://127.0.0.1:18500/health && printf '\\n' && curl -fsS http://127.0.0.1:18500/status",
    "backend:probe": "for path in /health /status /runtime/status /evaluations; do printf '%s ' \"$path\"; curl -sS -o /dev/null -w 'http=%{http_code} total=%{time_total}s ttfb=%{time_starttransfer}s\\n' --max-time 30 \"http://127.0.0.1:18500$path\"; done",
    "backend:health:public": "curl -fsS http://136.111.129.153:18500/health && printf '\\n' && curl -fsS http://136.111.129.153:18500/status",
    "calendar:refresh-loop": "scripts/macro-calendar-refresh.sh",
    "gateway:health": "curl -fsS http://127.0.0.1:18001/health",
    "gateway:probe": "for path in /health '/api/hyperliquid/overview?limit=5' /api/liquidations/status '/api/hyperliquid/paper/signals?limit=5' /api/hyperliquid/agent-runtime/status '/api/hyperliquid/agent-runs?limit=1' /api/hyperliquid/memory/graphify-status /api/hyperliquid/memory/graphify-explorer; do printf '%s ' \"$path\"; curl -sS -o /dev/null -w 'http=%{http_code} total=%{time_total}s ttfb=%{time_starttransfer}s\\n' --max-time 30 \"http://127.0.0.1:18001$path\"; done",
    "gateway:restart": "scripts/restart-hyperliquid-gateway.sh",
    "build:clean": "rm -rf dist dist-electron release && npm run build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:dir": "npm run build && electron-builder --mac --dir",
    "mac:verify": "scripts/mac-verify.sh",
    "mac:notarize": "scripts/mac-notarize.sh",
    "dist:win": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:dir": "npm run build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps && node scripts/fix-node-pty-permissions.mjs"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.4",
    "@google/genai": "^1.51.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.576.0",
    "node-pty": "^1.0.0",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^2.0.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^3.4.19",
    "three": "^0.184.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.184.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
