# Alpha engine runs on the VM and is reached locally through the SSH tunnel.
VITE_ALPHA_ENGINE_API_URL=http://127.0.0.1:18500
VITE_ALPHA_ENGINE_WS_URL=ws://127.0.0.1:18500

# Local Hyperliquid gateway. Required for Hyperliquid overview, liquidations,
# paper signals, and paper trades. This is separate from alpha-engine.
VITE_HYPERLIQUID_GATEWAY_API_URL=http://127.0.0.1:18001
VITE_HYPERLIQUID_GATEWAY_WS_URL=ws://127.0.0.1:18001

# Optional legacy trading backend.
VITE_LEGACY_API_URL=http://127.0.0.1:18000

# Compatibility aliases still accepted by src/services/backendConfig.ts.
VITE_API_URL=http://127.0.0.1:18500
VITE_WS_URL=ws://127.0.0.1:18500
VITE_POLYMARKET_BACKEND_URL=http://127.0.0.1:18500

AI_PROVIDER_ORDER=deepseek,openai
HF_AGENT_USE_AI=
HF_AGENT_CODEX_TIMEOUT_SECONDS=180
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.4-mini
OPENAI_CALENDAR_MODEL=gpt-5.4-mini

# Backend runtime artifact root. On the GCP VM, keep heavy evidence under /data
# instead of the repository checkout.
HYPERLIQUID_DATA_ROOT=/data
HF_HOST_DATA_ROOT=/data/hedge-fund-station/hyperliquid_gateway/data
